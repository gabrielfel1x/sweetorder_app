NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-your-anon-key"
# Chave "service_role" do Supabase (Project Settings → API). NUNCA exponha com prefixo
# NEXT_PUBLIC_ nem importe fora de código server-only — usada apenas no painel SaaS
# (app/superadmin) para convidar novos clientes por e-mail.
SUPABASE_SERVICE_ROLE_KEY="replace-with-your-service-role-key"
